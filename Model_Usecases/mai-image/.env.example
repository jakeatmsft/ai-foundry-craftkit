# MAI Image project configuration (Azure AD auth only, no API keys)
AZURE_ENDPOINT="https://eval-foundry.services.ai.azure.com"

DEPLOYMENT_NAME="MAI-IMAGE-2"

# Optional request defaults used by the notebook
IMAGE_PROMPT="A photorealistic image of an anthropomorphic axolotl in space with Mars in the background taking a selfie"
IMAGE_WIDTH="1024"
IMAGE_HEIGHT="1024"
OUTPUT_PATH="output.png"

# Optional: use these only when authenticating with a service principal.
# If omitted, DefaultAzureCredential can use Azure CLI / VS Code / Managed Identity.
# AZURE_TENANT_ID="<tenant-id>"
# AZURE_CLIENT_ID="<client-id>"
# AZURE_CLIENT_SECRET="<client-secret>"
